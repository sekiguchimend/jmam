# ==============================================
# 環境変数設定ファイル（サンプル）
# このファイルを .env.local にコピーして値を設定してください
# ==============================================

# ----------------------------------------------
# Supabase設定（必須）
# ----------------------------------------------
# Supabaseプロジェクトの設定 > API から取得
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Supabaseプロジェクトの設定 > API > service_role key から取得
# 注意: この値は絶対に公開しないでください（サーバーサイドでのみ使用）
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ----------------------------------------------
# Google AI (Gemini) API設定（任意）
# ----------------------------------------------
# Google AI Studio から取得
# https://aistudio.google.com/apikey
# どちらか一方を設定（GEMINI_API_KEYが優先）
GEMINI_API_KEY=your-gemini-api-key-here
# GOOGLE_API_KEY=your-google-api-key-here

# ----------------------------------------------
# セキュリティ設定（任意）
# ----------------------------------------------
# HTTPSが利用できない環境でCookieを許可する場合はtrueに設定
# 本番環境でHTTPSを使用する場合は設定不要（デフォルトでsecure: true）
# ALLOW_INSECURE_COOKIES=true

# ----------------------------------------------
# 注意事項
# ----------------------------------------------
# - .env.local は .gitignore に含まれているため、リポジトリにコミットされません
# - 本番環境では環境変数は直接設定してください（Vercel等のホスティング設定で）
# - SUPABASE_SERVICE_ROLE_KEY は特に機密性が高いため、取り扱いに注意してください
